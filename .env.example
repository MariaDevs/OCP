# Copy this to .env.local and fill in real values

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://onlinecasinoperu.com

# Google Analytics 4 Measurement ID (optional)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Contact form endpoint (optional — e.g. Formspree, Resend)
NEXT_PUBLIC_FORM_ENDPOINT=https://formspree.io/f/YOUR_ID

# --- Matching Visions Content Engine (blog) -------------------------------
# Build-time Spanish article feed for /blog. The blog merges these with the
# curated static posts. Leave BLANK to build with the static posts only.
# CE_API_URL must point at the engine's versioned API base (…/v1).
# CE_API_KEY is the site-scoped, articles:read key issued in the engine admin
# once OnlineCasinoPerú is registered as a site (default_language = es).
CE_API_URL=https://your-content-engine.example.com/v1
CE_API_KEY=
